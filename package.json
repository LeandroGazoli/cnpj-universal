{
  "name": "cnpj-universal",
  "version": "1.0.0",
  "description": "Validação de CNPJ numérico (legado) e alfanumérico (novo formato SERPRO) para NestJS e class-validator.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "jest"
  },
  "keywords": [
    "cnpj",
    "cnpj-alfanumerico",
    "validator",
    "nestjs",
    "class-validator",
    "brasil",
    "serpro"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "class-validator": ">=0.13.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "class-validator": "^0.15.1",
    "jest": "^30.3.0",
    "semantic-release": "^25.0.3",
    "ts-jest": "^29.4.9",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  }
}